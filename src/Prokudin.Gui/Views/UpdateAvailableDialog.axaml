<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Prokudin.Gui.Views.UpdateAvailableDialog"
        Title="Update Available"
        SizeToContent="WidthAndHeight"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
  <StackPanel Margin="24"
              Spacing="8"
              MinWidth="360"
              MaxWidth="520">
    <TextBlock Text="A newer version is available"
               FontSize="18"
               FontWeight="SemiBold" />
    <TextBlock x:Name="VersionTextBlock"
               TextWrapping="Wrap" />
    <TextBlock x:Name="ReleaseNotesTextBlock"
               TextWrapping="Wrap"
               MaxHeight="180"
               Classes="MutedCaption" />
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,8,0,0">
      <Button Content="Later"
              Click="OnLater" />
      <Button x:Name="OpenReleaseButton"
              Content="Open release page"
              Click="OnOpenRelease"
              IsDefault="True" />
    </StackPanel>
  </StackPanel>
</Window>
