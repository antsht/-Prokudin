<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="using:Avalonia.Automation"
             xmlns:primitives="using:Avalonia.Controls.Primitives"
             xmlns:vm="using:Prokudin.Gui.ViewModels"
             x:Class="Prokudin.Gui.Views.ContextBars.CleanContextBar"
             x:DataType="vm:MainViewModel">
  <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
    <primitives:ToggleButton Classes="IconButton"
                              IsChecked="{Binding IsHealToolMode}"
                              IsEnabled="{Binding IsUiEnabled}"
                              Content="{StaticResource IconHeal}"
                              ToolTip.Tip="Heal brush"
                              automation:AutomationProperties.Name="Heal brush"
                              Margin="0,0,4,0" />
    <primitives:ToggleButton Classes="IconButton"
                              IsChecked="{Binding IsCloneToolMode}"
                              IsEnabled="{Binding IsUiEnabled}"
                              Content="{StaticResource IconClone}"
                              ToolTip.Tip="Clone stamp"
                              automation:AutomationProperties.Name="Clone stamp"
                              Margin="0,0,8,0" />
    <Button Classes="IconButton"
            Command="{Binding AutoCleanSelectedChannelCommand}"
            Content="{StaticResource IconClean}"
            ToolTip.Tip="Detect auto-clean mask"
            automation:AutomationProperties.Name="Detect auto-clean mask"
            Margin="0,0,4,0" />
    <TextBlock Text="Brush"
               Classes="MutedCaption"
               VerticalAlignment="Center"
               Margin="0,0,4,0" />
    <Slider Width="80"
            Minimum="1"
            Maximum="64"
            Value="{Binding BrushSize}"
            IsEnabled="{Binding IsUiEnabled}"
            Margin="0,0,8,0" />
    <TextBlock Text="Radius"
               Classes="MutedCaption"
               VerticalAlignment="Center"
               Margin="0,0,4,0" />
    <Slider Width="64"
            Minimum="1"
            Maximum="12"
            Value="{Binding AutoCleanRadius}"
            IsEnabled="{Binding IsUiEnabled}"
            Margin="0,0,8,0" />
    <ProgressBar Width="96"
                 Height="10"
                 Minimum="0"
                 Maximum="100"
                 Value="{Binding AutoCleanProgress}"
                 IsVisible="{Binding IsAutoCleanProgressVisible}"
                 VerticalAlignment="Center"
                 Margin="0,0,8,0" />
    <Button Classes="IconButton"
            Command="{Binding ApplyAutoCleanMaskCommand}"
            Content="{StaticResource IconApply}"
            ToolTip.Tip="Apply auto-clean mask"
            automation:AutomationProperties.Name="Apply auto-clean mask"
            IsVisible="{Binding IsAutoCleanMaskPending}"
            Margin="0,0,4,0" />
    <Button Classes="IconButton"
            Command="{Binding CancelAutoCleanMaskCommand}"
            Content="{StaticResource IconCancel}"
            ToolTip.Tip="Cancel auto-clean mask"
            automation:AutomationProperties.Name="Cancel auto-clean mask"
            IsVisible="{Binding IsAutoCleanMaskPending}"
            Margin="0,0,4,0" />
    <primitives:ToggleButton Classes="IconButton"
                              IsChecked="{Binding ShowAutoCleanResultPreview}"
                              IsEnabled="{Binding IsUiEnabled}"
                              Content="{StaticResource IconPreview}"
                              ToolTip.Tip="Review mask on result"
                              automation:AutomationProperties.Name="Review mask on result"
                              IsVisible="{Binding IsAutoCleanMaskPending}" />
  </WrapPanel>
</UserControl>
