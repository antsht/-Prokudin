<controls:Window xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:controls="using:Avalonia.Controls"
                 xmlns:input="using:Avalonia.Input"
                 xmlns:views="using:Prokudin.Gui.Views"
                 xmlns:vm="using:Prokudin.Gui.ViewModels"
                 xmlns:z="using:Zafiro.Avalonia.Controls"
                 x:Class="Prokudin.Gui.Views.MainWindow"
                 x:DataType="vm:MainViewModel"
                 Title="Prokudin"
                 Width="1180"
                 Height="780"
                 MinWidth="880"
                 MinHeight="560">
  <controls:Window.KeyBindings>
    <input:KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}" />
    <input:KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}" />
  </controls:Window.KeyBindings>

  <DockPanel Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem Header="Open _Red..." Command="{Binding OpenRedCommand}" />
        <MenuItem Header="Open _Green..." Command="{Binding OpenGreenCommand}" />
        <MenuItem Header="Open _Blue..." Command="{Binding OpenBlueCommand}" />
        <Separator />
        <MenuItem Header="Open _Triptych..." Command="{Binding OpenTriptychCommand}" />
        <Separator />
        <MenuItem Header="_Export PNG..." Command="{Binding ExportCommand}" />
      </MenuItem>
      <MenuItem Header="_Edit">
        <MenuItem Header="_Undo" Command="{Binding UndoCommand}" />
        <MenuItem Header="_Redo" Command="{Binding RedoCommand}" />
      </MenuItem>
      <MenuItem Header="_Process">
        <MenuItem Header="_Auto-align" Command="{Binding AutoAlignCommand}" />
        <MenuItem Header="Auto-clean selected channel" Command="{Binding AutoCleanSelectedChannelCommand}" />
      </MenuItem>
    </Menu>

    <Border DockPanel.Dock="Top" Classes="ChromeBar top">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="Open R" Command="{Binding OpenRedCommand}" />
          <Button Content="Open G" Command="{Binding OpenGreenCommand}" />
          <Button Content="Open B" Command="{Binding OpenBlueCommand}" />
          <Button Content="Triptych" Command="{Binding OpenTriptychCommand}" />
          <ComboBox Width="84"
                    ItemsSource="{Binding TriptychOrders}"
                    SelectedItem="{Binding SelectedTriptychOrder}" />
          <Button Content="Auto-align" Command="{Binding AutoAlignCommand}" />
          <Button Content="Export PNG" Command="{Binding ExportCommand}" />
        </StackPanel>
        <z:EdgePanel Grid.Column="1">
          <z:EdgePanel.EndContent>
            <TextBlock Text="{Binding Status}" Classes="StatusText" />
          </z:EdgePanel.EndContent>
        </z:EdgePanel>
      </Grid>
    </Border>

    <Grid ColumnDefinitions="220,*">
      <z:HeaderedContainer Grid.Column="0"
                           Header="Channels"
                           Classes="Sidebar">
        <ListBox ItemsSource="{Binding Slots}"
                 SelectedItem="{Binding SelectedSlot}"
                 Padding="8"
                 Background="Transparent">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="vm:ChannelSlotViewModel">
              <views:ChannelSlotCard />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </z:HeaderedContainer>

      <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto,120">
        <Border Grid.Row="0" Classes="ChromeBar top" Padding="8,6">
          <WrapPanel Orientation="Horizontal"
                     VerticalAlignment="Center">
            <Button Content="{Binding FitToWindowButtonText}"
                    Command="{Binding ToggleFitToWindowCommand}"
                    Margin="0,0,8,0" />
            <Button Content="Crop to selection"
                    Command="{Binding CropToSelectionCommand}"
                    Margin="0,0,8,0" />
            <Button Content="Undo"
                    Command="{Binding UndoCommand}"
                    Margin="0,0,4,0" />
            <Button Content="Redo"
                    Command="{Binding RedoCommand}"
                    Margin="0,0,8,0" />
            <Button Content="Auto-clean"
                    Command="{Binding AutoCleanSelectedChannelCommand}"
                    Margin="0,0,8,0" />
            <CheckBox Content="Retouch"
                      IsChecked="{Binding IsRetouchMode}"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0" />
            <TextBlock Text="Brush"
                       Classes="MutedCaption"
                       VerticalAlignment="Center"
                       Margin="0,0,4,0" />
            <Slider Width="80"
                    Minimum="1"
                    Maximum="64"
                    Value="{Binding BrushSize}"
                    Margin="0,0,8,0" />
            <TextBlock Text="Sens"
                       Classes="MutedCaption"
                       VerticalAlignment="Center"
                       Margin="0,0,4,0" />
            <Slider Width="80"
                    Minimum="0"
                    Maximum="100"
                    Value="{Binding AutoCleanSensitivity}"
                    Margin="0,0,8,0" />
            <TextBlock Text="Radius"
                       Classes="MutedCaption"
                       VerticalAlignment="Center"
                       Margin="0,0,4,0" />
            <Slider Width="64"
                    Minimum="1"
                    Maximum="12"
                    Value="{Binding AutoCleanRadius}"
                    Margin="0,0,8,0" />
            <CheckBox Content="Auto WB"
                      IsChecked="{Binding AutoWhiteBalance}"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0" />
            <TextBlock Text="R"
                       Classes="MutedCaption"
                       VerticalAlignment="Center"
                       Margin="0,0,4,0" />
            <Slider Width="72"
                    Minimum="-2"
                    Maximum="2"
                    Value="{Binding RedExposureStops}"
                    Margin="0,0,8,0" />
            <TextBlock Text="G"
                       Classes="MutedCaption"
                       VerticalAlignment="Center"
                       Margin="0,0,4,0" />
            <Slider Width="72"
                    Minimum="-2"
                    Maximum="2"
                    Value="{Binding GreenExposureStops}"
                    Margin="0,0,8,0" />
            <TextBlock Text="B"
                       Classes="MutedCaption"
                       VerticalAlignment="Center"
                       Margin="0,0,4,0" />
            <Slider Width="72"
                    Minimum="-2"
                    Maximum="2"
                    Value="{Binding BlueExposureStops}"
                    Margin="0,0,8,0" />
            <Button Content="Reset exp"
                    Command="{Binding ResetExposureCommand}"
                    Margin="0,0,8,0" />
            <Button Content="Clear log"
                    Command="{Binding ClearLogCommand}" />
          </WrapPanel>
        </Border>

        <views:ImagePreviewControl Grid.Row="1"
                                   DisplayBitmap="{Binding SelectedSlot.DisplayBitmap}"
                                   ZoomMode="{Binding PreviewZoomMode}"
                                   SelectionRect="{Binding SelectionRect, Mode=TwoWay}"
                                   HasImage="{Binding SelectedSlot.HasImage}"
                                   InteractionMode="{Binding PreviewInteractionMode}"
                                   BrushSize="{Binding BrushSize}"
                                   InpaintRadius="{Binding AutoCleanRadius}"
                                   RetouchStrokeCommand="{Binding ApplyRetouchStrokeCommand}" />

        <Border Grid.Row="2" Classes="ChromeBar bottom" Padding="8,0">
          <z:EdgePanel>
            <z:EdgePanel.StartContent>
              <TextBlock Text="Dimensions" Classes="MutedCaption" />
            </z:EdgePanel.StartContent>
            <z:EdgePanel.EndContent>
              <TextBlock Text="{Binding SelectedSlot.Dimensions}" Classes="MutedCaption" />
            </z:EdgePanel.EndContent>
          </z:EdgePanel>
        </Border>

        <z:HeaderedContainer Grid.Row="3"
                             Header="Processing log"
                             Classes="LogPanel">
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Auto">
            <TextBox Text="{Binding ProcessingLogText}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     FontFamily="Consolas,Courier New,monospace"
                     FontSize="12"
                     MinHeight="100"
                     BorderThickness="0"
                     Background="Transparent" />
          </ScrollViewer>
        </z:HeaderedContainer>
      </Grid>
    </Grid>
  </DockPanel>
</controls:Window>
