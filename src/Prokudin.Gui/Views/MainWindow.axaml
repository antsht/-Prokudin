<controls:Window xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:automation="using:Avalonia.Automation"
                 xmlns:controls="using:Avalonia.Controls"
                 xmlns:input="using:Avalonia.Input"
                 xmlns:primitives="using:Avalonia.Controls.Primitives"
                 xmlns:inspector="using:Prokudin.Gui.Views.Inspector"
                 xmlns:views="using:Prokudin.Gui.Views"
                 xmlns:vm="using:Prokudin.Gui.ViewModels"
                 xmlns:z="using:Zafiro.Avalonia.Controls"
                 x:Class="Prokudin.Gui.Views.MainWindow"
                 x:DataType="vm:MainViewModel"
                 Title="{Binding WindowTitle}"
                 Width="1280"
                 Height="800"
                 MinWidth="920"
                 MinHeight="560">
  <controls:Window.KeyBindings>
    <input:KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}" />
    <input:KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}" />
    <input:KeyBinding Gesture="Ctrl+N" Command="{Binding NewProjectCommand}" />
    <input:KeyBinding Gesture="Ctrl+O" Command="{Binding OpenProjectCommand}" />
    <input:KeyBinding Gesture="Ctrl+S" Command="{Binding SaveProjectCommand}" />
    <input:KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveProjectAsCommand}" />
    <input:KeyBinding Gesture="D1" Command="{Binding SelectRedSlotShortcutCommand}" />
    <input:KeyBinding Gesture="NumPad1" Command="{Binding SelectRedSlotShortcutCommand}" />
    <input:KeyBinding Gesture="D2" Command="{Binding SelectGreenSlotShortcutCommand}" />
    <input:KeyBinding Gesture="NumPad2" Command="{Binding SelectGreenSlotShortcutCommand}" />
    <input:KeyBinding Gesture="D3" Command="{Binding SelectBlueSlotShortcutCommand}" />
    <input:KeyBinding Gesture="NumPad3" Command="{Binding SelectBlueSlotShortcutCommand}" />
    <input:KeyBinding Gesture="D4" Command="{Binding SelectResultSlotShortcutCommand}" />
    <input:KeyBinding Gesture="NumPad4" Command="{Binding SelectResultSlotShortcutCommand}" />
    <input:KeyBinding Gesture="H" Command="{Binding ActivateHealToolShortcutCommand}" />
    <input:KeyBinding Gesture="C" Command="{Binding ActivateCloneToolShortcutCommand}" />
    <input:KeyBinding Gesture="M" Command="{Binding ActivateSelectionToolShortcutCommand}" />
    <input:KeyBinding Gesture="OemOpenBrackets" Command="{Binding DecreaseBrushSizeShortcutCommand}" />
    <input:KeyBinding Gesture="OemCloseBrackets" Command="{Binding IncreaseBrushSizeShortcutCommand}" />
    <input:KeyBinding Gesture="L" Command="{Binding ToggleLoupeShortcutCommand}" />
  </controls:Window.KeyBindings>

  <Grid x:Name="RootGrid"
        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
        RowDefinitions="Auto,Auto,*,4,150,Auto">
    <Menu Grid.Row="0">
      <MenuItem Header="_File">
        <MenuItem Header="_New Project..." Command="{Binding NewProjectCommand}" InputGesture="Ctrl+N" />
        <MenuItem Header="_Open Project..." Command="{Binding OpenProjectCommand}" InputGesture="Ctrl+O" />
        <MenuItem Header="_Save Project" Command="{Binding SaveProjectCommand}" InputGesture="Ctrl+S" />
        <MenuItem Header="Save Project _As..." Command="{Binding SaveProjectAsCommand}" InputGesture="Ctrl+Shift+S" />
        <MenuItem Header="Open _Recent" x:Name="RecentProjectsMenuItem" />
        <Separator />
        <MenuItem Header="Open _Red..." Command="{Binding OpenRedCommand}" />
        <MenuItem Header="Open _Green..." Command="{Binding OpenGreenCommand}" />
        <MenuItem Header="Open _Blue..." Command="{Binding OpenBlueCommand}" />
        <Separator />
        <MenuItem Header="Open _Triptych..." Command="{Binding OpenTriptychCommand}" />
        <Separator />
        <MenuItem Header="Export _Result..." Command="{Binding ExportCommand}" />
        <MenuItem Header="Export _Channels..." Command="{Binding ExportChannelsCommand}" />
        <Separator />
        <MenuItem Header="E_xit" Command="{Binding ExitCommand}" />
      </MenuItem>
      <MenuItem Header="_Edit">
        <MenuItem Header="_Undo" Command="{Binding UndoCommand}" InputGesture="Ctrl+Z" />
        <MenuItem Header="_Redo" Command="{Binding RedoCommand}" InputGesture="Ctrl+Y" />
        <Separator />
        <MenuItem Header="_Settings..." Command="{Binding ShowSettingsCommand}" />
      </MenuItem>
      <MenuItem Header="_View">
        <MenuItem Header="_Theme">
          <MenuItem Header="_Light"
                    ToggleType="Radio"
                    IsChecked="{Binding IsLightThemeSelected}" />
          <MenuItem Header="_Dark"
                    ToggleType="Radio"
                    IsChecked="{Binding IsDarkThemeSelected}" />
          <MenuItem Header="_System"
                    ToggleType="Radio"
                    IsChecked="{Binding IsSystemThemeSelected}" />
        </MenuItem>
        <Separator />
        <MenuItem Header="Fit to _Window" Command="{Binding SetPreviewFitToWindowCommand}" />
        <MenuItem Header="_1:1" Command="{Binding SetPreviewOneToOneCommand}" />
        <Separator />
        <MenuItem Header="_Loupe"
                  ToggleType="CheckBox"
                  IsChecked="{Binding IsLoupeEnabled}"
                  InputGesture="L" />
        <Separator />
        <MenuItem Header="Show _Left Channel Panel"
                  ToggleType="CheckBox"
                  IsChecked="{Binding IsLeftPanelVisible}" />
        <MenuItem Header="Show _Right Inspector"
                  ToggleType="CheckBox"
                  IsChecked="{Binding IsRightInspectorVisible}" />
        <MenuItem Header="Show _Processing Log"
                  ToggleType="CheckBox"
                  IsChecked="{Binding IsProcessingLogVisible}" />
      </MenuItem>
      <MenuItem Header="_Process">
        <MenuItem Header="_Auto-align" Command="{Binding AutoAlignCommand}" />
        <MenuItem Header="_Rebuild Result" Command="{Binding RebuildResultCommand}" />
        <Separator />
        <MenuItem Header="Detect _Auto-clean Mask" Command="{Binding AutoCleanSelectedChannelCommand}" />
        <MenuItem Header="_Apply Auto-clean Mask" Command="{Binding ApplyAutoCleanMaskCommand}" />
        <MenuItem Header="_Cancel Auto-clean Mask" Command="{Binding CancelAutoCleanMaskCommand}" />
      </MenuItem>
      <MenuItem Header="_Tools">
        <MenuItem Header="_Selection" Command="{Binding SelectToolCommand}" CommandParameter="{x:Static vm:EditorToolMode.Select}" InputGesture="M" />
        <MenuItem Header="_Heal Brush" Command="{Binding SelectToolCommand}" CommandParameter="{x:Static vm:EditorToolMode.Heal}" InputGesture="H" />
        <MenuItem Header="_Clone Stamp" Command="{Binding SelectToolCommand}" CommandParameter="{x:Static vm:EditorToolMode.Clone}" InputGesture="C" />
        <MenuItem Header="_White Balance Picker" Command="{Binding SelectToolCommand}" CommandParameter="{x:Static vm:EditorToolMode.WhiteBalancePicker}" />
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Header="_User Guide" Command="{Binding OpenUserGuideCommand}" />
        <MenuItem Header="_Keyboard Shortcuts" Command="{Binding ShowKeyboardShortcutsCommand}" />
        <MenuItem Header="Check for _Updates..." Command="{Binding CheckForUpdatesCommand}" />
        <MenuItem Header="_About Prokudin" Command="{Binding ShowAboutCommand}" />
      </MenuItem>
    </Menu>

    <Border Grid.Row="1"
            x:Name="ContextBarHost"
            Classes="ChromeBar top"
            Padding="8,6">
      <views:ContextCommandBar DataContext="{Binding}" />
    </Border>

    <Grid Grid.Row="2"
          x:Name="WorkspaceGrid"
          ColumnDefinitions="260,4,88,*,4,360">
      <Grid x:Name="SidebarHost"
            Grid.Column="0"
            MinWidth="220"
            MaxWidth="420"
            IsVisible="{Binding IsLeftPanelVisible}">
        <z:HeaderedContainer Header="Channels" Classes="Sidebar">
          <ListBox ItemsSource="{Binding Slots}"
                   SelectedItem="{Binding SelectedSlot}"
                   Padding="8"
                   Background="Transparent">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:ChannelSlotViewModel">
                <views:ChannelSlotCard />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </z:HeaderedContainer>
        <Popup IsOpen="{Binding IsExportSettingsOpen}"
               PlacementTarget="{Binding #SidebarHost}"
               Placement="Right"
               HorizontalOffset="8"
               VerticalOffset="48"
               IsLightDismissEnabled="True">
          <Border Classes="ExportSettingsPopup" Width="280">
            <StackPanel Spacing="8">
              <TextBlock Text="Export settings" FontWeight="SemiBold" />
              <TextBlock Text="{Binding ExportSettingsSummary}" Classes="MutedCaption" />
              <Grid ColumnDefinitions="96,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                <TextBlock Text="Format" Classes="MutedCaption" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding ExportFormats}"
                          SelectedItem="{Binding ExportFormat}" />
                <CheckBox Grid.Row="1"
                          Grid.ColumnSpan="2"
                          Content="Limit max side"
                          IsChecked="{Binding LimitExportSize}" />
                <TextBlock Grid.Row="2"
                           Text="Max side"
                           Classes="MutedCaption"
                           VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="2"
                               Grid.Column="1"
                               Minimum="1"
                               Maximum="20000"
                               Increment="100"
                               Value="{Binding ExportMaxSide}"
                               IsEnabled="{Binding LimitExportSize}" />
              </Grid>
              <StackPanel Spacing="4" IsVisible="{Binding IsPngExport}">
                <TextBlock Text="PNG compression" Classes="MutedCaption" />
                <NumericUpDown Minimum="0"
                               Maximum="9"
                               Increment="1"
                               Value="{Binding PngCompression}" />
              </StackPanel>
              <StackPanel Spacing="4" IsVisible="{Binding IsJpegExport}">
                <TextBlock Text="JPEG quality" Classes="MutedCaption" />
                <NumericUpDown Minimum="1"
                               Maximum="100"
                               Increment="1"
                               Value="{Binding JpegQuality}" />
              </StackPanel>
              <StackPanel Spacing="6" IsVisible="{Binding IsTiffExport}">
                <TextBlock Text="TIFF compression" Classes="MutedCaption" />
                <ComboBox ItemsSource="{Binding TiffCompressions}"
                          SelectedItem="{Binding TiffCompression}" />
                <StackPanel Spacing="4" IsVisible="{Binding IsTiffDeflate}">
                  <TextBlock Text="Deflate level" Classes="MutedCaption" />
                  <NumericUpDown Minimum="1"
                                 Maximum="9"
                                 Increment="1"
                                 Value="{Binding TiffDeflateLevel}" />
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </Border>
        </Popup>
      </Grid>

      <GridSplitter x:Name="LeftColumnSplitter"
                    Grid.Column="1"
                    ResizeDirection="Columns"
                    Background="Transparent"
                    DragCompleted="OnLeftColumnSplitterDragCompleted"
                    IsVisible="{Binding IsLeftPanelVisible}" />

      <views:WorkflowToolbar Grid.Column="2"
                             DataContext="{Binding}" />

      <views:ImagePreviewControl Grid.Column="3"
                                 DisplayBitmap="{Binding PreviewDisplayBitmap}"
                                 MaskOverlayBitmap="{Binding AutoCleanMaskOverlayBitmap}"
                                 ZoomMode="{Binding PreviewZoomMode}"
                                 SelectionRect="{Binding SelectionRect, Mode=TwoWay}"
                                 LockSquareSelection="{Binding LockSquareSelection}"
                                 HasImage="{Binding PreviewHasImage}"
                                 InteractionMode="{Binding PreviewInteractionMode}"
                                 RetouchTool="{Binding SelectedRetouchTool}"
                                 PreviewImageContextKey="{Binding PreviewImageContextKey}"
                                 BrushSize="{Binding BrushSize}"
                                 InpaintRadius="{Binding AutoCleanRadius}"
                                 RetouchStrokeCommand="{Binding ApplyRetouchStrokeCommand}"
                                 StampStrokeCommand="{Binding ApplyStampStrokeCommand}"
                                 MaskEditCommand="{Binding EditAutoCleanMaskCommand}"
                                 WhiteBalancePickCommand="{Binding PickWhiteBalanceCommand}"
                                 IsLoupeEnabled="{Binding PreviewLoupeEnabled}" />

      <GridSplitter x:Name="RightColumnSplitter"
                    Grid.Column="4"
                    ResizeDirection="Columns"
                    Background="Transparent"
                    DragCompleted="OnRightColumnSplitterDragCompleted"
                    IsVisible="{Binding IsRightInspectorVisible}" />

      <Border Grid.Column="5"
              x:Name="InspectorHost"
              Classes="InspectorPanel"
              MinWidth="300"
              MaxWidth="520"
              IsVisible="{Binding IsRightInspectorVisible}">
        <inspector:InspectorPanel DataContext="{Binding}" />
      </Border>
    </Grid>

    <GridSplitter x:Name="LogRowSplitter"
                  Grid.Row="3"
                  ResizeDirection="Rows"
                  Background="Transparent"
                  DragCompleted="OnLogRowSplitterDragCompleted"
                  IsVisible="{Binding IsProcessingLogVisible}" />

    <views:ProcessingLogPanel Grid.Row="4"
                              DataContext="{Binding}"
                              IsVisible="{Binding IsProcessingLogVisible}" />

    <views:StatusBar Grid.Row="5"
                     DataContext="{Binding}" />
  </Grid>
</controls:Window>
