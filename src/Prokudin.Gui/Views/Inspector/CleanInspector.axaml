<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="using:Avalonia.Automation"
             xmlns:primitives="using:Avalonia.Controls.Primitives"
             xmlns:vm="using:Prokudin.Gui.ViewModels"
             xmlns:z="using:Zafiro.Avalonia.Controls"
             x:Class="Prokudin.Gui.Views.Inspector.CleanInspector"
             x:DataType="vm:MainViewModel">
  <StackPanel Spacing="0">
    <z:HeaderedContainer Header="Retouch tool"
                         Classes="InspectorSection">
      <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal"
                    Spacing="6">
          <primitives:ToggleButton Classes="IconButton"
                                    IsChecked="{Binding IsHealToolMode}"
                                    Content="{StaticResource IconHeal}"
                                    ToolTip.Tip="Heal brush"
                                    automation:AutomationProperties.Name="Heal brush" />
          <primitives:ToggleButton Classes="IconButton"
                                    IsChecked="{Binding IsCloneToolMode}"
                                    Content="{StaticResource IconClone}"
                                    ToolTip.Tip="Clone stamp"
                                    automation:AutomationProperties.Name="Clone stamp" />
        </StackPanel>
        <Grid ColumnDefinitions="120,*"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
              RowSpacing="6">
          <TextBlock Text="Brush size"
                     Classes="MutedCaption"
                     VerticalAlignment="Center" />
          <Slider Grid.Column="1"
                  Minimum="1"
                  Maximum="64"
                  Value="{Binding BrushSize}" />
          <TextBlock Grid.Row="1"
                     Text="Radius"
                     Classes="MutedCaption"
                     VerticalAlignment="Center" />
          <Slider Grid.Row="1"
                  Grid.Column="1"
                  Minimum="1"
                  Maximum="12"
                  Value="{Binding AutoCleanRadius}" />
          <TextBlock Grid.Row="2"
                     Text="Quality"
                     Classes="MutedCaption"
                     VerticalAlignment="Center" />
          <ComboBox Grid.Row="2"
                    Grid.Column="1"
                    ItemsSource="{Binding AutoCleanQualityModes}"
                    SelectedItem="{Binding AutoCleanQualityMode}" />
          <TextBlock Grid.Row="3"
                     Text="Sensitivity"
                     Classes="MutedCaption"
                     VerticalAlignment="Center" />
          <Slider Grid.Row="3"
                  Grid.Column="1"
                  Minimum="0"
                  Maximum="100"
                  Value="{Binding AutoCleanSensitivity}" />
          <TextBlock Grid.Row="4"
                     Text="Auto-clean"
                     Classes="MutedCaption"
                     VerticalAlignment="Center" />
          <Button Grid.Row="4"
                  Grid.Column="1"
                  Content="Detect mask"
                  Command="{Binding AutoCleanSelectedChannelCommand}"
                  HorizontalAlignment="Left"
                  automation:AutomationProperties.Name="Detect auto-clean mask" />
        </Grid>
      </StackPanel>
    </z:HeaderedContainer>

    <z:HeaderedContainer Header="Healing model"
                         Classes="InspectorSection">
      <StackPanel Spacing="6">
        <CheckBox Content="Cross-channel guided healing"
                  IsChecked="{Binding UseCrossChannelHealing}" />
        <CheckBox Content="Fallback sub-mode: Telea (off = Patch)"
                  IsChecked="{Binding UseTeleaHealing}" />
        <CheckBox Content="Use local linear prediction"
                  IsChecked="{Binding UseLocalLinearPrediction}" />
        <CheckBox Content="Use guided patch search"
                  IsChecked="{Binding UseGuidedPatchSearch}" />
        <CheckBox Content="Use robust fit"
                  IsChecked="{Binding UseRobustFit}" />
      </StackPanel>
    </z:HeaderedContainer>

    <z:HeaderedContainer Header="Mask preparation"
                         Classes="InspectorSection">
      <Grid ColumnDefinitions="160,*"
            RowDefinitions="Auto,Auto,Auto,Auto"
            RowSpacing="6">
        <TextBlock Text="Merge nearby defects"
                   Classes="MutedCaption"
                   VerticalAlignment="Center" />
        <CheckBox Grid.Column="1"
                  Content="Enabled"
                  IsChecked="{Binding AutoMergeNearbyDefects}"
                  VerticalAlignment="Center" />
        <TextBlock Grid.Row="1"
                   Text="Merge gap px"
                   Classes="MutedCaption"
                   VerticalAlignment="Center" />
        <NumericUpDown Grid.Row="1"
                       Grid.Column="1"
                       Minimum="0"
                       Maximum="64"
                       Increment="1"
                       Value="{Binding AutoMergeDistancePx}" />
        <TextBlock Grid.Row="2"
                   Text="Expand healing area px"
                   Classes="MutedCaption"
                   VerticalAlignment="Center" />
        <NumericUpDown Grid.Row="2"
                       Grid.Column="1"
                       Minimum="0"
                       Maximum="64"
                       Increment="1"
                       Value="{Binding AutoExpandHealingAreaPx}" />
        <TextBlock Grid.Row="3"
                   Text="Max component area"
                   Classes="MutedCaption"
                   VerticalAlignment="Center" />
        <NumericUpDown Grid.Row="3"
                       Grid.Column="1"
                       Minimum="100"
                       Maximum="50000"
                       Increment="100"
                       Value="{Binding HealMaxComponentArea}" />
      </Grid>
    </z:HeaderedContainer>

    <z:HeaderedContainer Header="Patch search"
                         Classes="InspectorSection">
      <Grid ColumnDefinitions="140,*"
            RowDefinitions="Auto,Auto,Auto,Auto,Auto"
            RowSpacing="6">
        <TextBlock Text="Patch radius"
                   Classes="MutedCaption"
                   VerticalAlignment="Center" />
        <NumericUpDown Grid.Column="1"
                       Minimum="1"
                       Maximum="12"
                       Increment="1"
                       Value="{Binding HealPatchRadius}" />
        <TextBlock Grid.Row="1"
                   Text="Search radius"
                   Classes="MutedCaption"
                   VerticalAlignment="Center" />
        <NumericUpDown Grid.Row="1"
                       Grid.Column="1"
                       Minimum="8"
                       Maximum="192"
                       Increment="4"
                       Value="{Binding HealSearchRadius}" />
        <TextBlock Grid.Row="2"
                   Text="Safety radius"
                   Classes="MutedCaption"
                   VerticalAlignment="Center" />
        <NumericUpDown Grid.Row="2"
                       Grid.Column="1"
                       Minimum="0"
                       Maximum="12"
                       Increment="1"
                       Value="{Binding HealSafetyRadius}" />
        <TextBlock Grid.Row="3"
                   Text="Context radius"
                   Classes="MutedCaption"
                   VerticalAlignment="Center" />
        <NumericUpDown Grid.Row="3"
                       Grid.Column="1"
                       Minimum="4"
                       Maximum="64"
                       Increment="2"
                       Value="{Binding HealContextRadius}" />
        <TextBlock Grid.Row="4"
                   Text="Min training pixels"
                   Classes="MutedCaption"
                   VerticalAlignment="Center" />
        <NumericUpDown Grid.Row="4"
                       Grid.Column="1"
                       Minimum="16"
                       Maximum="4096"
                       Increment="16"
                       Value="{Binding HealMinTrainingPixels}" />
      </Grid>
    </z:HeaderedContainer>

    <z:HeaderedContainer Header="Prediction blend"
                         Classes="InspectorSection">
      <Grid ColumnDefinitions="200,*"
            RowDefinitions="Auto,Auto,Auto,Auto,Auto"
            RowSpacing="6">
        <TextBlock Text="Prediction alpha min"
                   Classes="MutedCaption"
                   VerticalAlignment="Center" />
        <NumericUpDown Grid.Column="1"
                       Minimum="0"
                       Maximum="1"
                       Increment="0.05"
                       FormatString="F2"
                       Value="{Binding HealPredictionAlphaMin}" />
        <TextBlock Grid.Row="1"
                   Text="Prediction alpha max"
                   Classes="MutedCaption"
                   VerticalAlignment="Center" />
        <NumericUpDown Grid.Row="1"
                       Grid.Column="1"
                       Minimum="0"
                       Maximum="1"
                       Increment="0.05"
                       FormatString="F2"
                       Value="{Binding HealPredictionAlphaMax}" />
        <TextBlock Grid.Row="2"
                   Text="Feather sigma"
                   Classes="MutedCaption"
                   VerticalAlignment="Center" />
        <NumericUpDown Grid.Row="2"
                       Grid.Column="1"
                       Minimum="0.1"
                       Maximum="8"
                       Increment="0.1"
                       FormatString="F1"
                       Value="{Binding HealFeatherSigma}" />
        <TextBlock Grid.Row="3"
                   Text="Max allowed error"
                   Classes="MutedCaption"
                   VerticalAlignment="Center" />
        <NumericUpDown Grid.Row="3"
                       Grid.Column="1"
                       Minimum="0.01"
                       Maximum="1"
                       Increment="0.01"
                       FormatString="F2"
                       Value="{Binding HealMaxAllowedError}" />
        <TextBlock Grid.Row="4"
                   Text="Large component scale"
                   Classes="MutedCaption"
                   VerticalAlignment="Center" />
        <NumericUpDown Grid.Row="4"
                       Grid.Column="1"
                       Minimum="0.1"
                       Maximum="1"
                       Increment="0.05"
                       FormatString="F2"
                       Value="{Binding HealLargeComponentConservativeScale}" />
      </Grid>
    </z:HeaderedContainer>

    <z:HeaderedContainer Header="Debug"
                         Classes="InspectorSection">
      <StackPanel Spacing="6">
        <CheckBox Content="Debug heal output"
                  IsChecked="{Binding DebugHealOutput}" />
        <CheckBox Content="Show mask overlay"
                  IsChecked="{Binding ShowHealMaskOverlay}" />
        <CheckBox Content="Review mask on result"
                  IsChecked="{Binding ShowAutoCleanResultPreview}"
                  IsEnabled="{Binding IsAutoCleanMaskPending}" />
      </StackPanel>
    </z:HeaderedContainer>
  </StackPanel>
</UserControl>
