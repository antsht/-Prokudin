<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="using:Avalonia.Automation"
             xmlns:primitives="using:Avalonia.Controls.Primitives"
             xmlns:vm="using:Prokudin.Gui.ViewModels"
             xmlns:z="using:Zafiro.Avalonia.Controls"
             x:Class="Prokudin.Gui.Views.Inspector.CropInspector"
             x:DataType="vm:MainViewModel">
  <z:HeaderedContainer Header="Crop"
                       Classes="InspectorSection">
    <StackPanel Spacing="10">
      <Grid ColumnDefinitions="120,*"
            RowDefinitions="Auto,Auto,Auto,Auto"
            RowSpacing="6">
        <TextBlock Text="X"
                   Classes="MutedCaption"
                   VerticalAlignment="Center" />
        <NumericUpDown Grid.Column="1"
                       Minimum="0"
                       Maximum="20000"
                       Increment="1"
                       Value="{Binding SelectionX}" />
        <TextBlock Grid.Row="1"
                   Text="Y"
                   Classes="MutedCaption"
                   VerticalAlignment="Center" />
        <NumericUpDown Grid.Row="1"
                       Grid.Column="1"
                       Minimum="0"
                       Maximum="20000"
                       Increment="1"
                       Value="{Binding SelectionY}" />
        <TextBlock Grid.Row="2"
                   Text="Width"
                   Classes="MutedCaption"
                   VerticalAlignment="Center" />
        <NumericUpDown Grid.Row="2"
                       Grid.Column="1"
                       Minimum="0"
                       Maximum="20000"
                       Increment="1"
                       Value="{Binding SelectionWidth}" />
        <TextBlock Grid.Row="3"
                   Text="Height"
                   Classes="MutedCaption"
                   VerticalAlignment="Center" />
        <NumericUpDown Grid.Row="3"
                       Grid.Column="1"
                       Minimum="0"
                       Maximum="20000"
                       Increment="1"
                       Value="{Binding SelectionHeight}" />
      </Grid>
      <CheckBox Content="Lock square selection"
                IsChecked="{Binding LockSquareSelection}" />
      <TextBlock Text="{Binding CropBehaviorHint}"
                 Classes="MutedCaption"
                 TextWrapping="Wrap" />
      <StackPanel Spacing="6">
        <Button Content="Crop to selection"
                Command="{Binding CropToSelectionCommand}"
                HorizontalAlignment="Stretch"
                automation:AutomationProperties.Name="Crop to selection" />
        <Button Content="Crop overlap (all aligned)"
                Command="{Binding CropOverlapCommand}"
                HorizontalAlignment="Stretch"
                automation:AutomationProperties.Name="Crop overlap" />
        <Button Content="Reset selection"
                Command="{Binding ResetCropSelectionCommand}"
                HorizontalAlignment="Stretch"
                automation:AutomationProperties.Name="Reset crop selection" />
      </StackPanel>
      <primitives:ToggleButton Content="Selection mode"
                               Classes="IconButton"
                               IsChecked="{Binding IsSelectToolMode}"
                               HorizontalAlignment="Left"
                               ToolTip.Tip="Selection mode"
                               automation:AutomationProperties.Name="Selection mode" />
    </StackPanel>
  </z:HeaderedContainer>
</UserControl>
