<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:inspector="using:Prokudin.Gui.Views.Inspector"
             xmlns:vm="using:Prokudin.Gui.ViewModels"
             xmlns:z="using:Zafiro.Avalonia.Controls"
             x:Class="Prokudin.Gui.Views.Inspector.AlignInspector"
             x:DataType="vm:MainViewModel">
  <StackPanel Spacing="0">
    <z:HeaderedContainer Header="Alignment"
                         Classes="InspectorSection">
      <StackPanel Spacing="8">
        <Grid ColumnDefinitions="140,*"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
              RowSpacing="6">
          <inspector:InspectorParameterLabel x:Name="ReferenceChannelLabel"
                                             Caption="Reference channel"
                                             ShortTip="{StaticResource Tips.Align.ReferenceChannel.Short}"
                                             LongTip="{StaticResource Tips.Align.ReferenceChannel.Long}" />
          <ComboBox Grid.Column="1"
                    ItemsSource="{Binding AlignReferenceChannels}"
                    SelectedItem="{Binding AlignReference}"
                    ToolTip.ShowDelay="400"
                    ToolTip.Tip="{Binding ShortTip, ElementName=ReferenceChannelLabel}"
                    inspector:InspectorTipProperties.LongHelp="{StaticResource Tips.Align.ReferenceChannel.Long}" />
          <inspector:InspectorParameterLabel Grid.Row="1"
                                             x:Name="DetectorLabel"
                                             Caption="Detector"
                                             ShortTip="{StaticResource Tips.Align.Detector.Short}"
                                             LongTip="{StaticResource Tips.Align.Detector.Long}" />
          <ComboBox Grid.Row="1"
                    Grid.Column="1"
                    ItemsSource="{Binding AlignDetectors}"
                    SelectedItem="{Binding AlignDetector}"
                    ToolTip.ShowDelay="400"
                    ToolTip.Tip="{Binding ShortTip, ElementName=DetectorLabel}"
                    inspector:InspectorTipProperties.LongHelp="{StaticResource Tips.Align.Detector.Long}" />
          <inspector:InspectorParameterLabel Grid.Row="2"
                                             x:Name="MaxTranslationLabel"
                                             Caption="Max translation"
                                             ShortTip="{StaticResource Tips.Align.MaxTranslation.Short}"
                                             LongTip="{StaticResource Tips.Align.MaxTranslation.Long}" />
          <NumericUpDown Grid.Row="2"
                         Grid.Column="1"
                         Minimum="0"
                         Maximum="512"
                         Increment="8"
                         Value="{Binding AlignMaxTranslation}"
                         ToolTip.ShowDelay="400"
                         ToolTip.Tip="{Binding ShortTip, ElementName=MaxTranslationLabel}"
                         inspector:InspectorTipProperties.LongHelp="{StaticResource Tips.Align.MaxTranslation.Long}" />
          <inspector:InspectorParameterLabel Grid.Row="3"
                                             x:Name="MaxFineIterationsLabel"
                                             Caption="Max fine iterations"
                                             ShortTip="{StaticResource Tips.Align.MaxFineIterations.Short}"
                                             LongTip="{StaticResource Tips.Align.MaxFineIterations.Long}" />
          <NumericUpDown Grid.Row="3"
                         Grid.Column="1"
                         Minimum="0"
                         Maximum="20"
                         Increment="1"
                         Value="{Binding AlignMaxFineIterations}"
                         ToolTip.ShowDelay="400"
                         ToolTip.Tip="{Binding ShortTip, ElementName=MaxFineIterationsLabel}"
                         inspector:InspectorTipProperties.LongHelp="{StaticResource Tips.Align.MaxFineIterations.Long}" />
          <inspector:InspectorParameterLabel Grid.Row="4"
                                             x:Name="CoarseMaxSideLabel"
                                             Caption="Coarse max side"
                                             ShortTip="{StaticResource Tips.Align.CoarseMaxSide.Short}"
                                             LongTip="{StaticResource Tips.Align.CoarseMaxSide.Long}" />
          <NumericUpDown Grid.Row="4"
                         Grid.Column="1"
                         Minimum="256"
                         Maximum="4096"
                         Increment="128"
                         Value="{Binding AlignCoarseMaxSide}"
                         ToolTip.ShowDelay="400"
                         ToolTip.Tip="{Binding ShortTip, ElementName=CoarseMaxSideLabel}"
                         inspector:InspectorTipProperties.LongHelp="{StaticResource Tips.Align.CoarseMaxSide.Long}" />
        </Grid>
      </StackPanel>
    </z:HeaderedContainer>
    <z:HeaderedContainer Header="Alignment metadata"
                         Classes="InspectorSection">
      <StackPanel Spacing="6">
        <TextBlock Text="{Binding RedAlignSummary}"
                   TextWrapping="Wrap" />
        <TextBlock Text="{Binding GreenAlignSummary}"
                   TextWrapping="Wrap" />
        <TextBlock Text="{Binding BlueAlignSummary}"
                   TextWrapping="Wrap" />
      </StackPanel>
    </z:HeaderedContainer>
  </StackPanel>
</UserControl>
