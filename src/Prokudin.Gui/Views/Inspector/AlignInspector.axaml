<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Prokudin.Gui.ViewModels"
             xmlns:z="using:Zafiro.Avalonia.Controls"
             x:Class="Prokudin.Gui.Views.Inspector.AlignInspector"
             x:DataType="vm:MainViewModel">
  <StackPanel Spacing="0">
    <z:HeaderedContainer Header="Alignment"
                         Classes="InspectorSection">
      <StackPanel Spacing="8">
        <Grid ColumnDefinitions="140,*"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
              RowSpacing="6">
          <TextBlock Text="Reference channel"
                     Classes="MutedCaption"
                     VerticalAlignment="Center" />
          <ComboBox Grid.Column="1"
                    ItemsSource="{Binding AlignReferenceChannels}"
                    SelectedItem="{Binding AlignReference}" />
          <TextBlock Grid.Row="1"
                     Text="Detector"
                     Classes="MutedCaption"
                     VerticalAlignment="Center" />
          <ComboBox Grid.Row="1"
                    Grid.Column="1"
                    ItemsSource="{Binding AlignDetectors}"
                    SelectedItem="{Binding AlignDetector}" />
          <TextBlock Grid.Row="2"
                     Text="Max translation"
                     Classes="MutedCaption"
                     VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="2"
                         Grid.Column="1"
                         Minimum="0"
                         Maximum="512"
                         Increment="8"
                         Value="{Binding AlignMaxTranslation}"
                         ToolTip.Tip="Per-axis shift limit (0 = auto-scale)" />
          <TextBlock Grid.Row="3"
                     Text="Max fine iterations"
                     Classes="MutedCaption"
                     VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="3"
                         Grid.Column="1"
                         Minimum="0"
                         Maximum="20"
                         Increment="1"
                         Value="{Binding AlignMaxFineIterations}" />
          <TextBlock Grid.Row="4"
                     Text="Coarse max side"
                     Classes="MutedCaption"
                     VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="4"
                         Grid.Column="1"
                         Minimum="256"
                         Maximum="4096"
                         Increment="128"
                         Value="{Binding AlignCoarseMaxSide}" />
        </Grid>
      </StackPanel>
    </z:HeaderedContainer>
    <z:HeaderedContainer Header="Alignment metadata"
                         Classes="InspectorSection">
      <StackPanel Spacing="6">
        <TextBlock Text="{Binding RedAlignSummary}"
                   TextWrapping="Wrap" />
        <TextBlock Text="{Binding GreenAlignSummary}"
                   TextWrapping="Wrap" />
        <TextBlock Text="{Binding BlueAlignSummary}"
                   TextWrapping="Wrap" />
      </StackPanel>
    </z:HeaderedContainer>
  </StackPanel>
</UserControl>
