<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Prokudin.Gui.ViewModels"
        x:Class="Prokudin.Gui.Views.SettingsDialog"
        x:DataType="vm:SettingsDialogViewModel"
        Title="Settings"
        SizeToContent="WidthAndHeight"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
  <StackPanel Margin="24" Spacing="12" MinWidth="360">
    <TextBlock Text="Appearance" FontWeight="SemiBold" />
    <ComboBox ItemsSource="{Binding ThemeModes}"
              SelectedItem="{Binding ThemeMode}"
              HorizontalAlignment="Stretch" />

    <TextBlock Text="Autosave" FontWeight="SemiBold" Margin="0,8,0,0" />
    <CheckBox Content="Enable autosave"
              IsChecked="{Binding AutosaveEnabled}" />
    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="Interval (minutes):" VerticalAlignment="Center" />
      <NumericUpDown Minimum="1"
                     Maximum="60"
                     Value="{Binding AutosaveIntervalMinutes}"
                     Width="80" />
    </StackPanel>

    <TextBlock Text="Processing diagnostics" FontWeight="SemiBold" Margin="0,8,0,0" />
    <CheckBox Content="Log compute backends" IsChecked="{Binding LogComputeBackends}" />
    <CheckBox Content="Log pipeline stages" IsChecked="{Binding LogPipelineStages}" />
    <CheckBox Content="Log CPU parallel" IsChecked="{Binding LogCpuParallel}" />
    <CheckBox Content="Log timings" IsChecked="{Binding LogTimings}" />

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
      <Button Content="Cancel" Click="OnCancel" />
      <Button Content="OK" Click="OnOk" IsDefault="True" />
    </StackPanel>
  </StackPanel>
</Window>
