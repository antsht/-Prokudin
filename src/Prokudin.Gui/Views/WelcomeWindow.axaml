<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Prokudin.Gui.ViewModels"
        xmlns:views="using:Prokudin.Gui.Views"
        x:Class="Prokudin.Gui.Views.WelcomeWindow"
        x:DataType="vm:WelcomeViewModel"
        Title="Welcome to Prokudin"
        Width="600"
        Height="500"
        MinWidth="540"
        MinHeight="440"
        WindowStartupLocation="CenterScreen"
        CanResize="False">
  <Grid Margin="28"
        RowDefinitions="Auto,Auto,*,Auto"
        RowSpacing="16">
    <StackPanel Orientation="Horizontal" Spacing="12">
      <views:ChannelMark VerticalAlignment="Center" />
      <StackPanel Spacing="2">
        <TextBlock Text="Prokudin"
                   FontSize="26"
                   FontWeight="SemiBold" />
        <TextBlock Text="RGB reconstruction for Prokudin-Gorskii channel scans"
                   Classes="MutedCaption" />
      </StackPanel>
    </StackPanel>

    <Border Grid.Row="1" Classes="WelcomeHero">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
        <StackPanel Spacing="4">
          <TextBlock Text="Start a reconstruction" FontWeight="SemiBold" />
          <TextBlock Text="Import a triptych or three separate grayscale channels."
                     Classes="MutedCaption"
                     TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
          <Button Content="Separate channels…"
                  Command="{Binding OpenChannelsCommand}" />
          <Button Classes="PrimaryAction"
                  Content="Open triptych…"
                  Command="{Binding OpenTriptychCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="12">
        <Border Classes="WelcomeRecovery"
                IsVisible="{Binding HasAutosave}">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="4">
              <TextBlock Text="Recover autosave" FontWeight="SemiBold" />
              <TextBlock Text="{Binding AutosaveSummary}" Classes="MutedCaption" />
              <TextBlock Text="{Binding AutosaveLinkedProjectSummary}"
                         IsVisible="{Binding AutosaveLinkedProjectSummary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                         Classes="MutedCaption"
                         TextWrapping="Wrap" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Recover"
                    Command="{Binding RecoverAutosaveCommand}"
                    VerticalAlignment="Center" />
          </Grid>
        </Border>

        <TextBlock Text="Recent projects" FontWeight="SemiBold" />
        <ListBox x:Name="RecentList"
                 ItemsSource="{Binding RecentProjects}"
                 MinHeight="92"
                 SelectionChanged="RecentList_OnSelectionChanged">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Margin="4,2">
                <TextBlock Text="{Binding Path}" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding LastOpenedAt, StringFormat='Opened {0:g}'}"
                           Classes="MutedCaption" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        <TextBlock Text="No recent projects yet."
                   IsVisible="{Binding !RecentProjects.Count}"
                   Classes="MutedCaption" />
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="3"
                Orientation="Horizontal"
                Spacing="8"
                HorizontalAlignment="Right">
      <Button Classes="QuietAction"
              Content="Settings"
              Click="Settings_OnClick" />
      <Button Content="Open project…"
              Command="{Binding OpenOtherCommand}" />
      <Button Classes="QuietAction"
              Content="Blank project"
              Command="{Binding NewProjectCommand}" />
    </StackPanel>
  </Grid>
</Window>
