<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Prokudin.Gui.Views.KeyboardShortcutsDialog"
        Title="Keyboard Shortcuts"
        SizeToContent="WidthAndHeight"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
  <StackPanel Margin="24"
              Spacing="10"
              MinWidth="360">
    <TextBlock Text="Keyboard Shortcuts"
               FontSize="18"
               FontWeight="SemiBold" />
    <TextBlock TextWrapping="Wrap"
               Classes="MutedCaption"
               Text="Global shortcuts work when the main window has focus." />
    <Grid ColumnDefinitions="140,*"
          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
          RowSpacing="6">
      <TextBlock Text="New project"
                 FontWeight="SemiBold" />
      <TextBlock Grid.Column="1"
                 Text="Ctrl+N" />
      <TextBlock Grid.Row="1"
                 Text="Open project"
                 FontWeight="SemiBold" />
      <TextBlock Grid.Row="1"
                 Grid.Column="1"
                 Text="Ctrl+O" />
      <TextBlock Grid.Row="2"
                 Text="Save project"
                 FontWeight="SemiBold" />
      <TextBlock Grid.Row="2"
                 Grid.Column="1"
                 Text="Ctrl+S" />
      <TextBlock Grid.Row="3"
                 Text="Save project as"
                 FontWeight="SemiBold" />
      <TextBlock Grid.Row="3"
                 Grid.Column="1"
                 Text="Ctrl+Shift+S" />
      <TextBlock Grid.Row="4"
                 Text="Undo"
                 FontWeight="SemiBold" />
      <TextBlock Grid.Row="4"
                 Grid.Column="1"
                 Text="Ctrl+Z" />
      <TextBlock Grid.Row="5"
                 Text="Redo"
                 FontWeight="SemiBold" />
      <TextBlock Grid.Row="5"
                 Grid.Column="1"
                 Text="Ctrl+Y" />
      <TextBlock Grid.Row="6"
                 Text="Selection"
                 FontWeight="SemiBold" />
      <TextBlock Grid.Row="6"
                 Grid.Column="1"
                 Text="Tools → Selection, or Crop workflow toolbar" />
      <TextBlock Grid.Row="7"
                 Text="Heal / Clone"
                 FontWeight="SemiBold" />
      <TextBlock Grid.Row="7"
                 Grid.Column="1"
                 Text="Tools menu or Clean workflow toolbar" />
      <TextBlock Grid.Row="8"
                 Text="Zoom"
                 FontWeight="SemiBold" />
      <TextBlock Grid.Row="8"
                 Grid.Column="1"
                 Text="View → Fit to Window / 1:1, or inspector header" />
      <TextBlock Grid.Row="9"
                 Text="Preview tools"
                 FontWeight="SemiBold" />
      <TextBlock Grid.Row="9"
                 Grid.Column="1"
                 Text="Mouse: drag selection, brush strokes, clone source+destination"
                 TextWrapping="Wrap" />
    </Grid>
    <Button Content="OK"
            HorizontalAlignment="Right"
            Margin="0,8,0,0"
            Click="OnClose"
            IsDefault="True" />
  </StackPanel>
</Window>
