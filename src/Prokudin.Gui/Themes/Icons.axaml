<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="clr-namespace:Zafiro.UI;assembly=Zafiro.UI">
  <ui:Icon x:Key="IconOpenImage" Source="fa-file-image" />
  <ui:Icon x:Key="IconTriptych" Source="fa-table-columns" />
  <ui:Icon x:Key="IconExport" Source="fa-file-export" />
  <ui:Icon x:Key="IconSettings" Source="fa-gear" />
  <ui:Icon x:Key="IconAlign" Source="fa-arrows-left-right" />
  <ui:Icon x:Key="IconZoomFit" Source="fa-expand" />
  <ui:Icon x:Key="IconCrop" Source="fa-crop" />
  <ui:Icon x:Key="IconUndo" Source="fa-rotate-left" />
  <ui:Icon x:Key="IconRedo" Source="fa-rotate-right" />
  <ui:Icon x:Key="IconClean" Source="fa-broom" />
  <ui:Icon x:Key="IconPointer" Source="fa-arrow-pointer" />
  <ui:Icon x:Key="IconHeal" Source="fa-bandage" />
  <ui:Icon x:Key="IconClone" Source="fa-clone" />
  <ui:Icon x:Key="IconWhiteBalance" Source="fa-circle-half-stroke" />
  <ui:Icon x:Key="IconClear" Source="fa-trash" />
</ResourceDictionary>
